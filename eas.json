{
  "cli": {
    "version": ">= 19.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": true,
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EXPO_NO_BYTECODE": "1",
          "NODE_ENV": "production"
        },
        "image": "latest",
        "resourceClass": "large"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "universal": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "EXPO_NO_BYTECODE": "1",
          "NODE_ENV": "production"
        },
        "config": "release"
      }
    },
    "ios-production": {
      "ios": {
        "buildConfiguration": "Release",
        "env": {
          "EXPO_NO_BYTECODE": "1",
          "NODE_ENV": "production"
        },
        "simulator": false,
        "image": "latest"
      }
    },
    "ios-simulator": {
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
