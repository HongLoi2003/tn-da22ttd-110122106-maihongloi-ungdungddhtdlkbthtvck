# EmailJS Configuration
# Lấy từ: https://dashboard.emailjs.com/

# 1. Service ID - từ Email Services (Gmail, Outlook, etc.)
EMAILJS_SERVICE_ID=service_n1dxg9i

# 2. Template ID - từ Email Templates
# Template cho OTP
EMAILJS_OTP_TEMPLATE_ID=template_6mijrdd
# Template cho xác nhận lịch hẹn
EMAILJS_APPOINTMENT_TEMPLATE_ID=template_xxxxxxx

# 3. Public Key - từ Account > General
EMAILJS_PUBLIC_KEY=3NS4CiOX1XZ6ntgpUhQJW

# Hướng dẫn lấy keys:
# 1. Đăng nhập: https://dashboard.emailjs.com/
# 2. Verify email nếu chưa
# 3. Email Services → Add/Select service → Copy Service ID
# 4. Email Templates → Create template → Copy Template ID
# 5. Account → General → Copy Public Key
